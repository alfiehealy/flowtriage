        "Send_an_email_V2": {
          "type": "ApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_office365"
            },
            "parameters": {
              "emailMessage/To": "warehouse@contoso.com",
              "emailMessage/Subject": "Stock alert"
            }
          },
          "runAfter": {}
        }
      }
    },
    "connectionReferences": {
      "shared_office365": {
        "connectionName": "shared_office365",
        "source": "Embedded",
        "connectionOwner": "sioned.evans@contoso.com"
