{
  "name": "flow-16",
  "id": "/providers/Microsoft.Flow/flows/16a10074",
  "properties": {
    "displayName": "Incident P1 Escalation",
    "state": "Started",
    "createdTime": "2023-10-11T09:00:00Z",
    "lastModifiedTime": "2025-08-01T14:30:00Z",
    "creator": {
      "userPrincipalName": "dylan.hughes@contoso.com"
    },
    "definition": {
      "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
      "triggers": {
        "When_an_item_is_created": {
          "type": "ApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_sharepointonline"
            },
            "parameters": {
              "dataset": "https://contoso.sharepoint.com/sites/Operations",
              "table": "Incident List"
            }
          }
        }
      },
      "actions": {
        "Step_1_teams": {
          "type": "ApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_teams"
            },
            "parameters": {}
          },
          "runAfter": {}
        },
        "Step_2_outlook": {
          "type": "ApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_office365"
            },
            "parameters": {}
          },
          "runAfter": {
            "Step_1_teams": [
              "Succeeded"
            ]
          }
        },
        "Notify_on_failure": {
          "type": "ApiConnection",
          "inputs": {
            "host": {
              "connectionName": "shared_teams"
            },
            "parameters": {
              "message": "Flow failed"
            }
          },
          "runAfter": {
            "Step_2_outlook": [
              "Failed",
              "TimedOut"
            ]
          }
        }
      }
    },
    "connectionReferences": {
      "shared_teams": {
        "connectionName": "shared_teams",
        "source": "Embedded",
        "connectionOwner": "SVC-automation@contoso.com"
      },
      "shared_office365": {
        "connectionName": "shared_office365",
        "source": "Embedded",
        "connectionOwner": "SVC-automation@contoso.com"
      }
    }
  }
}